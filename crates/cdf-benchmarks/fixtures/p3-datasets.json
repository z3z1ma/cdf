  "workloads": [
    {
      "id": "legacy_tiny_startup_e2e",
      "dataset_id": "legacy_tiny_startup",
      "operation": "Isolated CDF process startup through DuckDB receipt and committed checkpoint",
      "timed_region": {
        "version": 1,
        "includes": ["child process startup", "fixture generation", "project compile", "source decode", "validation", "package", "DuckDB destination", "receipt", "checkpoint"],
        "excludes": ["macro request serialization", "report serialization"]
      },
      "logical_byte_counter": {"name": "decoded_arrow_bytes", "method": "sum engine output logical bytes"},
      "physical_byte_counter": {"name": "source_and_package_bytes", "method": "fixture file bytes plus package identity file bytes"}
    },
    {
      "id": "legacy_medium_ndjson_package",
      "dataset_id": "legacy_medium_throughput",
      "operation": "Prepared medium NDJSON source read through verified package finalization",
      "timed_region": {
        "version": 1,
        "includes": ["source reads", "NDJSON decode", "validation", "package encode", "hash", "finalize"],
        "excludes": ["child process startup", "fixture generation", "destination commit", "report serialization"]
      },
      "logical_byte_counter": {"name": "decoded_arrow_bytes", "method": "sum engine output logical bytes"},
      "physical_byte_counter": {"name": "source_bytes", "method": "prepared NDJSON file metadata length"}
    },
    {
      "id": "tlc_parquet_to_package",
      "dataset_id": "nyc_tlc_yellow_2024",
      "operation": "CDF source decode through verified package finalization",
      "timed_region": {
        "version": 1,
        "includes": ["source reads", "decode", "validation", "package encode", "hash", "finalize"],
        "excludes": ["dataset acquisition", "destination commit"]
      },
      "logical_byte_counter": {"name": "decoded_arrow_bytes", "method": "sum batch logical bytes"},
      "physical_byte_counter": {"name": "source_bytes", "method": "transport/file byte counter"}
    },
    {
      "id": "tpch_csv_to_package",
      "dataset_id": "tpch_sf10",
      "operation": "CDF CSV decode through verified package finalization",
      "timed_region": {
        "version": 1,
        "includes": ["source reads", "decode", "validation", "package encode", "hash", "finalize"],
        "excludes": ["dataset generation", "destination commit"]
      },
      "logical_byte_counter": {"name": "decoded_arrow_bytes", "method": "sum batch logical bytes"},
      "physical_byte_counter": {"name": "source_bytes", "method": "transport/file byte counter"}
    },
    {
      "id": "constant_memory_stress",
      "dataset_id": "constant_memory_100g",
      "operation": "Generated source through verified destination/checkpoint completion",
      "timed_region": {
        "version": 1,
        "includes": ["source generation in measured child", "pipeline", "package", "destination", "checkpoint"],
        "excludes": ["runner setup", "report serialization"]
      },
      "logical_byte_counter": {"name": "generated_bytes", "method": "deterministic generator counter"},
      "physical_byte_counter": {"name": "persisted_bytes", "method": "artifact and destination writer receipts"}
    }
  ]
}
