.TH cdf-plan 1  "cdf-plan "
.SH NAME
cdf\-plan
.SH SYNOPSIS
\fBcdf plan\fR [\fB\-\-resource\fR] [\fB\-\-select\fR] [\fB\-\-filter\fR] [\fB\-\-limit\fR] [\fB\-\-order\-by\fR] [\fB\-\-package\-id\fR] [\fB\-\-to\fR] [\fB\-\-target\fR] [\fB\-\-no\-pin\fR] [\fB\-h\fR|\fB\-\-help\fR] [\fIRESOURCE\fR]
.SH DESCRIPTION
.SH OPTIONS
.TP
\fB\-\-resource\fR \fI<RESOURCE>\fR

.TP
\fB\-\-select\fR \fI<FIELDS>\fR

.TP
\fB\-\-filter\fR \fI<EXPR>\fR

.TP
\fB\-\-limit\fR \fI<N>\fR

.TP
\fB\-\-order\-by\fR \fI<FIELD[:asc|desc]>\fR

.TP
\fB\-\-package\-id\fR \fI<ID>\fR

.TP
\fB\-\-to\fR \fI<DEST>\fR

.TP
\fB\-\-target\fR \fI<TARGET>\fR

.TP
\fB\-\-no\-pin\fR

.TP
\fB\-h\fR, \fB\-\-help\fR
Print help
.TP
[\fIRESOURCE\fR]
